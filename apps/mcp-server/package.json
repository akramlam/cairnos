{
  "name": "@cairn/mcp-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "cairn-mcp": "src/index.ts"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "start": "tsx src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --external:better-sqlite3 --banner:js=\"import{createRequire}from'module';const require=createRequire(import.meta.url);\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cairn/core": "workspace:*",
    "@cairn/db": "workspace:*",
    "@cairn/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "esbuild": "^0.24.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
