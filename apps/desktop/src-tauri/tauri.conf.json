{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CairnOS",
  "version": "0.1.1",
  "identifier": "com.cairnos.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm -C ../.. dev",
    "beforeBuildCommand": "pnpm --filter @cairn/desktop build && node ../../scripts/build-engine.mjs"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "CairnOS",
        "width": 1320,
        "height": 860,
        "minWidth": 980,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "visible": false,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": ["sidecar/**/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEEzQjY5NjU1OTM0NDM4NkQKUldSdE9FU1RWWmEybzJPRE5UUFpDZHNzVHROeENoMUE4QVJmK3ZhWTJVelhkV2lxeHNOL0drSXMK",
      "endpoints": [
        "https://github.com/akramlam/cairnos/releases/latest/download/latest.json"
      ]
    }
  }
}
